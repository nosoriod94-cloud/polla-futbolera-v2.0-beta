VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Email del superadmin (quien puede acceder a /superadmin y gestionar licencias)
VITE_SUPERADMIN_EMAIL=your-superadmin-email@example.com

# Secret para autenticar el cron que invoca la Edge Function assign-default-predictions
# Configúralo también en Supabase Dashboard → Edge Functions → Secrets → CRON_SECRET
# CRON_SECRET=un-valor-secreto-largo-y-aleatorio
